@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="profile-switch">
            <NavLink class="profile-switch__item" ActiveClass="profile-switch__item--active" href="proyectos-ruben">
                <img src="images/profiles/ruben.jpg" alt="Rubén Martín" class="profile-switch__avatar" />
                <div class="profile-switch__text">
                    <span class="profile-switch__name">Rubén Martín</span>
                    <span class="profile-switch__role">
                        <span class="bi bi-telephone-fill" aria-hidden="true"></span>
                        +34 622 045 103
                    </span>
                </div>
            </NavLink>

            <NavLink class="profile-switch__item" ActiveClass="profile-switch__item--active" href="proyectos-javier">
                <img src="images/profiles/javi.jpeg" alt="Javier Canales" class="profile-switch__avatar" />
                <div class="profile-switch__text">
                    <span class="profile-switch__name">Javier Canales</span>
                    <span class="profile-switch__role">
                        <span class="bi bi-telephone-fill" aria-hidden="true"></span>
                        +34 616 338 551
                    </span>
                </div>
            </NavLink>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

