@page "/proyectos-ruben"
@inject NavigationManager Navigation

<PageTitle>Ruben Martin | Curriculum</PageTitle>

<div class="portfolio-page portfolio-ruben">
    <section class="portfolio-hero">
        <div class="portfolio-hero__badge">Curriculum</div>
        <h1>Ruben Martin Novalbos</h1>
    </section>

    <section class="portfolio-grid">
        <article class="portfolio-card">
            <h2>Educacion</h2>
            <ul class="portfolio-list">
                <li>DAM - 2026 - Murcia</li>
                <li>ESAD - 2000 - Cordoba</li>
                <li>COU - 1995 - Puertollano</li>
            </ul>
        </article>

        <article class="portfolio-card">
            <h2>Experiencia laboral</h2>
            <ul class="portfolio-list">
                <li>Montaje - 2003/2023 - Cartagena</li>
                <li>Artes escenicas - 1998/2001 - Cordoba</li>
            </ul>
        </article>

        <article class="portfolio-card">
            <h2>Habilidades</h2>
            <ul class="portfolio-list">
                <li>Continuo aprendizaje</li>
                <li>Devoto de la programacion</li>
                <li>Tenaz y resolutivo</li>
            </ul>
        </article>

        <article class="portfolio-card portfolio-card--full">
            <h2>Proyecto</h2>
            <div class="portfolio-table-wrap">
                <table class="portfolio-table">
                    <thead>
                        <tr>
                            <th>Imagen</th>
                            <th>Proyecto</th>
                            <th>Descripcion</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="project-row-link">
                            <td data-label="Imagen">
                                <a class="project-cell-link" href="@($"{Navigation.BaseUri}java-swing")">
                                    <img class="portfolio-thumb" src="images/projects/common/project-placeholder.svg" alt="Imagen generica de proyecto" />
                                </a>
                            </td>
                            <td data-label="Proyecto">
                                <a class="project-cell-link" href="@($"{Navigation.BaseUri}java-swing")">java-swing</a>
                            </td>
                            <td data-label="Descripcion">
                                <a class="project-cell-link" href="@($"{Navigation.BaseUri}java-swing")">Proyecto Java/Swing. Pulsa la fila para ver su pagina dedicada.</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </article>
    </section>

    <footer class="social-footer">
        <span class="social-link social-link--muted">
            <span class="bi bi-linkedin" aria-hidden="true"></span> LinkedIn (pendiente)
        </span>
        <a class="social-link" href="https://github.com/martinbb8" target="_blank" rel="noopener noreferrer">
            <span class="bi bi-github" aria-hidden="true"></span> GitHub
        </a>
        <a class="social-link" href="https://www.facebook.com/ciclismoacuatico" target="_blank" rel="noopener noreferrer">
            <span class="bi bi-facebook" aria-hidden="true"></span> Facebook
        </a>
        <a class="social-link" href="mailto:ciclismoacuatico@gmail.com">
            <span class="bi bi-envelope-fill" aria-hidden="true"></span> Email
        </a>
        <span class="social-link social-link--text">
            <span class="bi bi-geo-alt-fill" aria-hidden="true"></span> Los Urrutias-Cartagena (Murcia)
        </span>
    </footer>
</div>

